---
export interface Props {
  data: {
    errorCode?: string;
    errorTitle?: string;
    errorMessage?: string;
    returnHomeText?: string;
  };
}

const { data } = Astro.props;
---

<div class="h-screen flex flex-col items-center justify-center text-center px-6" data-dr-section="error-page">
  <div class="text-[10px] font-medium tracking-[0.2em] uppercase text-accent mb-8">
    Error
  </div>

  <h1
    class="font-serif text-8xl md:text-9xl text-primary mb-4"
    data-dr-field="errorCode"
  >
    {data.errorCode}
  </h1>

  <p
    class="text-2xl font-serif text-primary mb-4"
    data-dr-field="errorTitle"
  >
    {data.errorTitle}
  </p>

  <p
    class="text-muted text-sm mb-12 max-w-md font-light leading-relaxed"
    data-dr-field="errorMessage"
  >
    {data.errorMessage}
  </p>

  <a
    href="/"
    class="text-[11px] font-medium tracking-[0.2em] uppercase px-10 py-4 border border-primary text-primary hover:bg-primary hover:text-white transition-colors duration-500"
  >
    <span data-dr-field="returnHomeText">
      {data.returnHomeText}
    </span>
  </a>
</div>
