---
export interface Props {
  data: {
    eyebrow?: string;
    heading?: string;
    body?: string;
  };
}

const { data } = Astro.props;
---

<section class="py-32 px-6 md:px-12 bg-surface" data-dr-section="introduction">
  <div class="max-w-[1200px] mx-auto grid grid-cols-1 md:grid-cols-12 gap-16 items-center">

    <div class="md:col-span-5">
      {data.eyebrow && (
        <div
          class="text-[10px] font-medium tracking-[0.2em] uppercase text-accent mb-6"
          data-dr-field="eyebrow"
        >
          {data.eyebrow}
        </div>
      )}
      {data.heading && (
        <h2
          class="font-serif text-4xl md:text-5xl leading-tight"
          data-dr-field="heading"
        >
          {data.heading}
        </h2>
      )}
    </div>

    <div class="md:col-span-7">
      {data.body && (
        <p
          class="text-base md:text-lg text-muted leading-relaxed font-light"
          data-dr-field="body"
        >
          {data.body}
        </p>
      )}
    </div>

  </div>
</section>
