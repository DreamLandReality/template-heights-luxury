---
export interface Props {
  data: {
    eyebrow?: string;
    heading?: string;
    mediaType: 'image' | 'video' | 'iframe';
    mediaFile?: string;
    mediaAlt?: string;
    iframeUrl?: string;
    iframeTitle?: string;
    caption?: string;
  };
}

const { data } = Astro.props;
const imgSrc = (path: string) => path?.startsWith('http') ? path : `/${path}`;

const isImage = data.mediaType === 'image';
const isVideo = data.mediaType === 'video';
const isIframe = data.mediaType === 'iframe';
---

<section class="py-32 px-6 md:px-12 bg-white" id="media-showcase" data-dr-section="media-showcase">
  <div class="max-w-[1400px] mx-auto">

    <div class="text-center mb-16">
      {data.eyebrow && (
        <div
          class="text-[10px] font-medium tracking-[0.2em] uppercase text-accent mb-4"
          data-dr-field="eyebrow"
        >
          {data.eyebrow}
        </div>
      )}
      {data.heading && (
        <h2
          class="font-serif text-4xl md:text-5xl uppercase"
          data-dr-field="heading"
        >
          {data.heading}
        </h2>
      )}
    </div>

    <div class="relative w-full aspect-video bg-primary overflow-hidden">

      <!-- Image Mode -->
      <div
        data-dr-show-when="media-showcase.mediaType=image"
        style={isImage ? '' : 'display:none'}
        class="w-full h-full"
      >
        <img
          src={imgSrc(data.mediaFile || 'defaults/default-hero.jpg')}
          alt={data.mediaAlt || data.heading || 'Property media'}
          class="w-full h-full object-cover"
          data-dr-field="mediaFile"
          loading="lazy"
        />
      </div>

      <!-- Video Mode -->
      <div
        data-dr-show-when="media-showcase.mediaType=video"
        style={isVideo ? '' : 'display:none'}
        class="relative w-full h-full"
      >
        <div
          id="media-video-skeleton"
          class="absolute inset-0 bg-primary flex items-center justify-center"
        >
          <div class="w-12 h-12 border-4 border-white/20 border-t-accent rounded-full animate-spin"></div>
        </div>
        <video
          src={imgSrc(data.mediaFile || 'defaults/demo-video.mp4')}
          muted
          controls
          class="w-full h-full object-cover opacity-0 transition-opacity duration-500"
          data-dr-field="mediaFile"
          onloadeddata="this.style.opacity='1'; document.getElementById('media-video-skeleton').style.display='none';"
          oncanplay="this.style.opacity='1'; document.getElementById('media-video-skeleton').style.display='none';"
        >
          Your browser does not support the video tag.
        </video>
      </div>

      <!-- Iframe Mode (YouTube / 360 tour) -->
      <div
        data-dr-show-when="media-showcase.mediaType=iframe"
        style={isIframe ? '' : 'display:none'}
        class="w-full h-full"
      >
        <iframe
          src={data.iframeUrl || ''}
          title={data.iframeTitle || 'Virtual Tour'}
          class="absolute inset-0 w-full h-full opacity-80 hover:opacity-100 transition-opacity duration-700"
          frameborder="0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
          data-dr-field="iframeUrl"
        ></iframe>
        <div class="absolute inset-0 pointer-events-none border border-white/10 m-4"></div>
      </div>
    </div>

    {data.caption && (
      <p class="text-sm text-muted text-center mt-6 tracking-wide" data-dr-field="caption">
        {data.caption}
      </p>
    )}
  </div>
</section>
